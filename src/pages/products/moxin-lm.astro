                    <span class="px-3 py-1 rounded-full text-xs font-semibold bg-accent-purple/10 text-accent-purple border border-accent-purple/15">
                      {item}
                    </span>
                  ))}
                </div>

                <h3 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-text-inverse">Moxin Voice</h3>
                <p class="text-base md:text-lg text-text-secondary dark:text-text-secondary-inverse leading-relaxed max-w-3xl">
                  Text-to-speech and automatic speech recognition that run entirely on-device, with no cloud API dependency and a strong focus on speed, privacy, and flexible deployment.
                </p>

                <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-center">
                  <div class="space-y-3">
                    {voiceCapabilities.map((item) => (
                      <div class="flex items-start gap-3">
                        <span class="mt-1 flex h-5 w-5 items-center justify-center rounded-full bg-accent-purple/10 text-accent-purple shrink-0">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                        </span>
                        <p class="text-sm md:text-base text-text-secondary dark:text-text-secondary-inverse leading-relaxed">{item}</p>
                      </div>
                    ))}
                  </div>

                  <div class="flex items-center justify-center lg:-translate-y-8">
                    <div class="w-full max-w-[320px]">
                      <a href="https://github.com/moxin-org/Moxin-Voice" target="_blank" class="inline-flex w-full items-center justify-center gap-2 px-5 py-3 rounded-full bg-accent-purple text-white font-semibold shadow-lg shadow-purple-500/20 hover:bg-purple-600 transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.1 3.29 9.43 7.86 10.96.58.1.79-.25.79-.56 0-.27-.01-1.18-.02-2.14-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.72-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.48.11-3.08 0 0 .97-.31 3.18 1.18a11.1 11.1 0 015.79 0c2.2-1.49 3.17-1.18 3.17-1.18.64 1.6.24 2.79.12 3.08.74.8 1.19 1.83 1.19 3.09 0 4.43-2.69 5.4-5.25 5.69.41.36.77 1.07.77 2.16 0 1.56-.01 2.82-.01 3.21 0 .31.21.67.8.56a11.53 11.53 0 007.85-10.96C23.5 5.66 18.35.5 12 .5z"></path></svg>
                        View on GitHub
                      </a>
                    </div>
                  </div>
                </div>

                <div class="w-full lg:w-[70%] mx-auto rounded-[1.75rem] border border-gray-200 dark:border-white/10 bg-white/75 dark:bg-white/5 backdrop-blur-sm p-4 md:p-5 shadow-sm">
                  <div class="flex items-center justify-between gap-4 mb-4">
                    <p class="text-base font-semibold text-text-primary dark:text-text-inverse">Voice Sample</p>
                    <span class="text-xs px-3 py-1 rounded-full bg-accent-purple/10 text-accent-purple border border-accent-purple/15">WAV</span>
                  </div>

                  <div class="flex flex-col md:flex-row items-stretch md:items-center gap-3 md:gap-4">
                    <div class="md:w-28 h-20 rounded-[1.35rem] bg-white dark:bg-white/10 border border-gray-200 dark:border-white/10 flex items-center justify-center shrink-0">
                      <div class="flex items-center gap-1.5">
                        <div class="w-1.5 bg-accent-purple h-8 animate-pulse rounded-full"></div>
                        <div class="w-1.5 bg-accent-purple h-14 animate-pulse rounded-full" style="animation-delay: 0.1s"></div>
                        <div class="w-1.5 bg-accent-purple h-10 animate-pulse rounded-full" style="animation-delay: 0.2s"></div>
                        <div class="w-1.5 bg-accent-purple h-12 animate-pulse rounded-full" style="animation-delay: 0.3s"></div>
                        <div class="w-1.5 bg-accent-purple h-7 animate-pulse rounded-full" style="animation-delay: 0.4s"></div>
                      </div>
                    </div>

                    <div class="flex-1 bg-white dark:bg-white/10 rounded-[1.35rem] p-3 md:p-4 border border-gray-200 dark:border-white/10">
                      <div class="flex items-center gap-3">
                        <button id="voice-play-btn" aria-label="Play voice sample" class="w-11 h-11 md:w-12 md:h-12 flex items-center justify-center bg-accent-purple text-white rounded-full hover:bg-purple-600 transition-colors shrink-0 shadow-md shadow-purple-500/20">
                          <svg id="voice-play-icon" class="w-5 h-5 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path></svg>
                          <svg id="voice-pause-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6"></path></svg>
                        </button>
                        <div class="flex-1">
                          <p class="text-base font-semibold text-text-primary dark:text-text-inverse mb-2">Moxin Voice Maple sample</p>
                          <input type="range" id="voice-seek-slider" class="w-full h-1.5 bg-gray-200 dark:bg-gray-600 rounded-lg appearance-none cursor-pointer accent-accent-purple" value="0" max="100">
                        </div>
                        <audio id="voice-demo-audio" src={mkPath("/resources/moxin-voice-demo-maple.wav")} preload="metadata"></audio>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="w-full lg:w-[70%] mx-auto rounded-[2rem] border border-accent-purple/15 dark:border-accent-purple/25 bg-white/80 dark:bg-slate-950/35 backdrop-blur-sm p-3 md:p-4 shadow-[0_24px_60px_-28px_rgba(59,130,246,0.28)]">
                <div class="rounded-[1.5rem] overflow-hidden border border-accent-purple/10 dark:border-white/10 bg-slate-100 dark:bg-slate-950/70">
                  <video class="block w-full h-auto" autoplay loop muted playsinline preload="metadata">
                    <source src={mkPath("/resources/moxin-voice-demo-en.mp4")} type="video/mp4" />
                    Your browser does not support the video tag.
                  </video>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6 max-w-6xl mx-auto">
          {voiceHighlights.map((item) => (
            <div class="bg-white dark:bg-white/5 p-6 rounded-3xl border border-gray-200 dark:border-white/10 shadow-sm hover:shadow-md hover:border-accent-purple/40 transition-all">
              <h3 class="text-lg font-bold mb-3 text-text-primary dark:text-text-inverse">{item.title}</h3>
              <p class="text-sm leading-relaxed text-text-secondary dark:text-text-secondary-inverse">{item.description}</p>
            </div>
          ))}
        </div>

        <script>
          const audio = document.getElementById('voice-demo-audio');
          const playBtn = document.getElementById('voice-play-btn');
          const playIcon = document.getElementById('voice-play-icon');
          const pauseIcon = document.getElementById('voice-pause-icon');
          const seekSlider = document.getElementById('voice-seek-slider');

          if (audio && playBtn && playIcon && pauseIcon && seekSlider) {
            const syncIcons = () => {
              if (audio.paused) {
                playIcon.classList.remove('hidden');
                pauseIcon.classList.add('hidden');
              } else {
                playIcon.classList.add('hidden');
                pauseIcon.classList.remove('hidden');
              }
            };

            playBtn.addEventListener('click', () => {
              if (audio.paused) {
                audio.play();
              } else {
                audio.pause();
              }
              syncIcons();
            });

            audio.addEventListener('play', syncIcons);
            audio.addEventListener('pause', syncIcons);

            audio.addEventListener('timeupdate', () => {
              if (!audio.duration) return;
              seekSlider.value = String((audio.currentTime / audio.duration) * 100);
            });

            seekSlider.addEventListener('input', () => {
              if (!audio.duration) return;
              audio.currentTime = (Number(seekSlider.value) / 100) * audio.duration;
            });

            audio.addEventListener('ended', () => {
              seekSlider.value = '0';
              syncIcons();
            });
          }
        </script>
      </div>

    </div>

    <div class="grid md:grid-cols-2 gap-12 mb-24">
      <div class="bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-3xl p-8 col-span-2">
        <h2 class="text-3xl font-bold mb-6 text-text-primary dark:text-text-inverse text-center">Build with Moxin LM</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white dark:bg-white/10 p-6 rounded-xl shadow-sm">
            <h3 class="text-lg font-bold mb-2 text-accent-purple">Robotics & Automation</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse text-sm">Fine-tune for specific robotics commands and industrial applications.</p>
          </div>
          <div class="bg-white dark:bg-white/10 p-6 rounded-xl shadow-sm">
            <h3 class="text-lg font-bold mb-2 text-accent-purple">Edge AI Solutions</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse text-sm">Run AI directly on devices for privacy-first, low-latency applications.</p>
          </div>
          <div class="bg-white dark:bg-white/10 p-6 rounded-xl shadow-sm">
            <h3 class="text-lg font-bold mb-2 text-accent-purple">Research Platform</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse text-sm">Ideal for academic research with full reproducibility and transparency.</p>
          </div>
        </div>
      </div>
    </div>


  </div>
</Layout>
