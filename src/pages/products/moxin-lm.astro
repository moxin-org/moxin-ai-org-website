          <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-3xl p-6 shadow-sm hover:shadow-md hover:border-accent-purple transition-all">
            <h3 class="text-xl font-bold mb-4 text-text-primary dark:text-text-inverse break-words">DeepSeek V3</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse text-sm mb-4">
              Latest DeepSeek V3 model optimized for Moxin.
            </p>
            <div class="flex gap-3">
              <a href="https://huggingface.co/moxin-org/DeepSeek-V3-0324-Moxin-GGUF" target="_blank" class="w-full bg-white dark:bg-white/5 hover:bg-gray-50 dark:hover:bg-white/10 text-text-primary dark:text-text-inverse px-4 py-2 rounded-full text-sm font-medium border border-gray-200 dark:border-white/10 transition-all flex items-center justify-center gap-2">
                <img src="/images/hf-logo.svg" class="w-4 h-4" alt="HF" />
                Learn More
