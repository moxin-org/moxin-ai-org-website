                <img src="/images/hf-logo.svg" class="w-4 h-4" alt="HF" />
                Learn More
              </a>
            </div>
          </div>

          <!-- Qwen3 235B -->
          <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-3xl p-6 shadow-sm hover:shadow-md hover:border-accent-purple transition-all">
            <h3 class="text-xl font-bold mb-4 text-text-primary dark:text-text-inverse break-words">Qwen3 235B</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse text-sm mb-4">
              Massive 235B parameter model quantized for deployment.
