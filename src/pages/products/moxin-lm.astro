            <div class="flex gap-3">
              <a href="https://huggingface.co/moxin-org/Qwen3-235B-A22B-Instruct-2507-GGUF" target="_blank" class="w-full bg-white dark:bg-white/5 hover:bg-gray-50 dark:hover:bg-white/10 text-text-primary dark:text-text-inverse px-4 py-2 rounded-full text-sm font-medium border border-gray-200 dark:border-white/10 transition-all flex items-center justify-center gap-2">
                <img src="/images/hf-logo.svg" class="w-4 h-4" alt="HF" />
