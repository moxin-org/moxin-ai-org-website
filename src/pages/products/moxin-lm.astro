  <div class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
    <div class="text-center mb-16 animate-fade-in">
      <h1 class="text-5xl font-bold mb-6 text-text-primary dark:text-text-inverse">
        Moxin LM <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-purple to-purple-400">
          Open Source Foundation Models
        </span>
      </h1>
      <p class="text-xl text-text-secondary dark:text-text-secondary-inverse max-w-3xl mx-auto font-light">
        From reasoning to speech, our models are designed for the next generation of human-computer interaction.
      </p>
    </div>

    <div class="max-w-3xl mx-auto mb-16 animate-fade-in relative z-10">
      <div class="bg-white dark:bg-white/5 bg-gradient-to-r from-accent-purple/10 to-purple-100 dark:from-purple-900/20 dark:to-purple-800/20 border border-accent-purple/20 rounded-3xl p-8 shadow-lg hover:shadow-xl transition-all cursor-pointer text-center transform hover:scale-105" onclick="window.open('https://huggingface.co/moxin-org', '_blank')">
