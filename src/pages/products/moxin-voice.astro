      <p class="text-sm text-text-secondary dark:text-text-secondary-inverse mb-6">
        Requires macOS 14.0+ (Sonoma) &bull; Apple Silicon (M1/M2/M3/M4) &bull; Rust 1.82+ &bull; Dora CLI
      </p>
      <div class="bg-gray-900 dark:bg-black/40 rounded-xl p-5 font-mono text-sm text-violet-400 overflow-x-auto">
        <p class="text-gray-500"># Install Dora CLI</p>
        <p>cargo install dora-cli --locked</p>
        <p class="mt-3 text-gray-500"># Clone the repository</p>
        <p>git clone https://github.com/moxin-org/Moxin-Voice.git</p>
        <p>cd Moxin-Voice</p>
        <p class="mt-3 text-gray-500"># Download TTS models (~3.5 GB)</p>
        <p>python3 scripts/download_models.py</p>
        <p class="mt-3 text-gray-500"># Build and run</p>
        <p>cargo build --release</p>
        <p>dora up && dora start apps/moxin-voice/dataflow/tts.yml</p>
      </div>
