        </span>
      </div>
      
      <!-- Navigation Links -->
      <!-- Navigation Links -->
      <div class="flex justify-center gap-6 mt-8">
        <a href="#open-creation" class="text-text-secondary dark:text-text-secondary-inverse hover:text-accent-purple dark:hover:text-accent-purple transition-colors font-medium flex items-center gap-1">
