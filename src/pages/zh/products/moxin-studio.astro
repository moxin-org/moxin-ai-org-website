---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Moxin Studio - Moxin Org">
  <!-- Hero -->
  <div class="pt-32 pb-16 px-6 max-w-7xl mx-auto text-center">
    <h1 class="text-5xl font-bold mb-8 text-text-primary dark:text-text-inverse animate-fade-in">
      Moxin Studio <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-500 to-cyan-500">
        纯 Rust 原生桌面 AI 应用
      </span>
    </h1>
    <p class="text-xl text-text-secondary dark:text-text-secondary-inverse max-w-3xl mx-auto mb-12 font-light">
      在本地运行大语言模型、生成图像、克隆语音、转录语音 — 全部在你的硬件上完成，无需 Python 运行时。基于纯 Rust 和 <a href="https://github.com/makepad/makepad" target="_blank" class="text-teal-600 dark:text-teal-400 hover:underline">Makepad</a> 构建。
    </p>

    <div class="max-w-3xl mx-auto mb-12 animate-fade-in relative z-10">
      <div class="bg-white dark:bg-white/5 bg-gradient-to-r from-teal-500/10 to-cyan-500/10 dark:from-teal-900/20 dark:to-cyan-900/20 border border-teal-500/20 rounded-3xl p-8 shadow-lg hover:shadow-xl transition-all cursor-pointer text-center transform hover:scale-105" onclick="window.open('https://github.com/moxin-org/Moxin-Studio', '_blank')">
        <h3 class="text-2xl font-bold mb-3 text-text-primary dark:text-text-inverse">在 GitHub 上探索</h3>
        <p class="text-text-secondary dark:text-text-secondary-inverse mb-4 text-lg">浏览源代码，参与贡献，使用 Moxin Studio 构建应用。</p>
        <span class="text-teal-600 font-bold text-lg flex items-center justify-center gap-2">
          github.com/moxin-org/Moxin-Studio
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </span>
      </div>
    </div>

    <!-- Key Capabilities -->
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mb-4">
      <div class="text-center">
        <p class="text-4xl font-bold text-teal-600 dark:text-teal-400">6</p>
        <p class="text-sm text-text-secondary dark:text-text-secondary-inverse mt-1">模态 (LLM, VLM, ASR, TTS, 图像, 视频)</p>
      </div>
      <div class="text-center">
        <p class="text-4xl font-bold text-teal-600 dark:text-teal-400">20+</p>
        <p class="text-sm text-text-secondary dark:text-text-secondary-inverse mt-1">支持的本地模型</p>
      </div>
      <div class="text-center">
        <p class="text-4xl font-bold text-teal-600 dark:text-teal-400">0</p>
        <p class="text-sm text-text-secondary dark:text-text-secondary-inverse mt-1">Python 依赖</p>
      </div>
    </div>
    <p class="text-xs text-text-secondary dark:text-text-secondary-inverse mb-8">运行于 macOS 14.0+ (Sonoma) &bull; Apple Silicon (M1&ndash;M5)</p>
  </div>

  <!-- Demo Video -->
  <div class="px-6 max-w-5xl mx-auto mb-20">
    <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-3xl overflow-hidden shadow-lg">
      <video class="w-full" controls playsinline poster="/images/moxin-studio/screenshot-image-gen.png">
        <source src="/videos/moxin-studio-demo.mp4" type="video/mp4" />
      </video>
    </div>
  </div>

  <!-- Screenshots -->
  <div class="px-6 max-w-5xl mx-auto mb-20">
    <h2 class="text-3xl font-bold text-center mb-10 text-text-primary dark:text-text-inverse">界面一览</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        <img src="/images/moxin-studio/screenshot-image-gen.png" alt="Moxin Studio 图像生成" class="w-full" />
        <div class="p-4">
          <h3 class="font-bold text-text-primary dark:text-text-inverse">图像生成</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary-inverse">使用 FLUX.2-klein 在本地生成图像</p>
        </div>
      </div>
      <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        <img src="/images/moxin-studio/screenshot-vlm.png" alt="Moxin Studio 视觉理解" class="w-full" />
        <div class="p-4">
          <h3 class="font-bold text-text-primary dark:text-text-inverse">视觉语言模型</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary-inverse">使用 Moxin-7B VLM 描述和理解图像</p>
        </div>
      </div>
      <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        <img src="/images/moxin-studio/screenshot-model-hub.png" alt="Moxin Studio 模型中心" class="w-full" />
        <div class="p-4">
          <h3 class="font-bold text-text-primary dark:text-text-inverse">模型中心</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary-inverse">发现、下载和管理本地模型</p>
        </div>
      </div>
      <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        <img src="/images/moxin-studio/screenshot-history.png" alt="Moxin Studio 会话历史" class="w-full" />
        <div class="p-4">
          <h3 class="font-bold text-text-primary dark:text-text-inverse">会话历史</h3>
          <p class="text-sm text-text-secondary dark:text-text-secondary-inverse">持久化、可搜索的对话记录</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Features -->
  <div class="px-6 max-w-5xl mx-auto mb-20">
    <h2 class="text-3xl font-bold text-center mb-10 text-text-primary dark:text-text-inverse">功能特性</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10 hover:shadow-md transition-shadow">
        <div class="h-10 w-10 bg-teal-50 dark:bg-teal-900/30 rounded-lg flex items-center justify-center text-teal-600 dark:text-teal-400 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
        </div>
        <h3 class="text-lg font-bold mb-2 text-text-primary dark:text-text-inverse">本地 AI 推理</h3>
        <p class="text-text-secondary dark:text-text-secondary-inverse text-sm leading-relaxed">
          通过 OminiX-API 在 Mac 上直接运行大语言模型、视觉模型、图像生成、语音识别和语音合成。
        </p>
      </div>
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10 hover:shadow-md transition-shadow">
        <div class="h-10 w-10 bg-teal-50 dark:bg-teal-900/30 rounded-lg flex items-center justify-center text-teal-600 dark:text-teal-400 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        </div>
        <h3 class="text-lg font-bold mb-2 text-text-primary dark:text-text-inverse">模型中心</h3>
        <p class="text-text-secondary dark:text-text-secondary-inverse text-sm leading-relaxed">
          在应用内发现、下载和运行模型。一键下载，自动设置后端。
        </p>
      </div>
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10 hover:shadow-md transition-shadow">
        <div class="h-10 w-10 bg-teal-50 dark:bg-teal-900/30 rounded-lg flex items-center justify-center text-teal-600 dark:text-teal-400 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>
        </div>
        <h3 class="text-lg font-bold mb-2 text-text-primary dark:text-text-inverse">语音输入输出</h3>
        <p class="text-text-secondary dark:text-text-secondary-inverse text-sm leading-relaxed">
          语音转文字和文字转语音，支持语音克隆。由 Qwen3-ASR、GPT-SoVITS 等驱动。
        </p>
      </div>
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10 hover:shadow-md transition-shadow">
        <div class="h-10 w-10 bg-teal-50 dark:bg-teal-900/30 rounded-lg flex items-center justify-center text-teal-600 dark:text-teal-400 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-lg font-bold mb-2 text-text-primary dark:text-text-inverse">图像与视频生成</h3>
        <p class="text-text-secondary dark:text-text-secondary-inverse text-sm leading-relaxed">
          使用 FLUX.2-klein 和 Z-Image 生成图像。使用 Qwen-Image-Edit 编辑图像。使用 Wan2.2 创建视频。
        </p>
      </div>
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10 hover:shadow-md transition-shadow">
        <div class="h-10 w-10 bg-teal-50 dark:bg-teal-900/30 rounded-lg flex items-center justify-center text-teal-600 dark:text-teal-400 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path></svg>
        </div>
        <h3 class="text-lg font-bold mb-2 text-text-primary dark:text-text-inverse">MCP 支持</h3>
        <p class="text-text-secondary dark:text-text-secondary-inverse text-sm leading-relaxed">
          模型上下文协议 (MCP)，实现工具使用。将 AI 连接到外部工具和数据源。
        </p>
      </div>
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10 hover:shadow-md transition-shadow">
        <div class="h-10 w-10 bg-teal-50 dark:bg-teal-900/30 rounded-lg flex items-center justify-center text-teal-600 dark:text-teal-400 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="text-lg font-bold mb-2 text-text-primary dark:text-text-inverse">会话历史</h3>
        <p class="text-text-secondary dark:text-text-secondary-inverse text-sm leading-relaxed">
          持久化、可搜索的对话记录。跨会话无缝衔接。
        </p>
      </div>
    </div>
  </div>

  <!-- Supported Models -->
  <div class="px-6 max-w-5xl mx-auto mb-20">
    <h2 class="text-3xl font-bold text-center mb-4 text-text-primary dark:text-text-inverse">支持的本地模型</h2>
    <p class="text-center text-text-secondary dark:text-text-secondary-inverse mb-10 max-w-2xl mx-auto">
      每个模型都有专用的优化实现，而非通用封装。纯 Rust 模型通过 OminiX-MLX 直接运行，使用 Metal GPU 加速。
    </p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- LLM -->
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10">
        <h3 class="text-lg font-bold mb-3 text-text-primary dark:text-text-inverse flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          大语言模型
        </h3>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Qwen3 (0.6B–8B)</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Qwen3.5-27B</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">GLM-4 / 4.5 / 4.7</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Mistral / Nemo</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Mixtral</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">MiniCPM-SALA</span>
        </div>
      </div>
      <!-- VLM -->
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10">
        <h3 class="text-lg font-bold mb-3 text-text-primary dark:text-text-inverse flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          视觉模型
        </h3>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Qwen3-VL</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Moxin-7B</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">DeepSeek-OCR-2</span>
        </div>
      </div>
      <!-- ASR -->
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10">
        <h3 class="text-lg font-bold mb-3 text-text-primary dark:text-text-inverse flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          语音识别
        </h3>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Qwen3-ASR (30+ 语言)</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Paraformer</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">FunASR-Nano</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">SenseVoice + Qwen3</span>
        </div>
      </div>
      <!-- TTS -->
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10">
        <h3 class="text-lg font-bold mb-3 text-text-primary dark:text-text-inverse flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          语音合成
        </h3>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Qwen3-TTS</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">GPT-SoVITS</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Step-Audio 2</span>
        </div>
      </div>
      <!-- Image Gen -->
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10">
        <h3 class="text-lg font-bold mb-3 text-text-primary dark:text-text-inverse flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          图像生成
        </h3>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">FLUX.2-klein</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Z-Image-Turbo</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Qwen-Image</span>
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Cosmos Predict2 14B</span>
        </div>
      </div>
      <!-- Video Gen -->
      <div class="bg-white dark:bg-white/5 p-6 rounded-2xl border border-gray-200 dark:border-white/10">
        <h3 class="text-lg font-bold mb-3 text-text-primary dark:text-text-inverse flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          视频生成
        </h3>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs px-2 py-1 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-full">Wan2.2 5B</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Platform Architecture -->
  <div class="px-6 max-w-5xl mx-auto mb-20">
    <h2 class="text-3xl font-bold text-center mb-10 text-text-primary dark:text-text-inverse">平台架构</h2>
    <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-3xl p-8 shadow-sm">
      <div class="space-y-4">
        <!-- Moxin Studio -->
        <div class="bg-gradient-to-r from-teal-50 to-cyan-50 dark:from-teal-900/20 dark:to-cyan-900/20 border border-teal-200 dark:border-teal-700/30 rounded-2xl p-6">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
              <h3 class="text-lg font-bold text-text-primary dark:text-text-inverse">Moxin Studio</h3>
              <p class="text-sm text-text-secondary dark:text-text-secondary-inverse">桌面 UI &mdash; Rust + Makepad</p>
            </div>
            <div class="flex flex-wrap gap-3 text-xs text-teal-700 dark:text-teal-300">
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">对话</span>
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">模型中心</span>
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">语音</span>
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">MCP</span>
            </div>
          </div>
        </div>
        <!-- Arrow -->
        <div class="flex justify-center text-gray-400 dark:text-gray-600">
          <div class="text-center">
            <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
            <span class="text-xs">兼容 OpenAI 的 REST/WS 接口</span>
          </div>
        </div>
        <!-- OminiX-API -->
        <a href="/zh/products/ominix" class="block bg-gradient-to-r from-emerald-50 to-green-50 dark:from-emerald-900/20 dark:to-green-900/20 border border-emerald-200 dark:border-emerald-700/30 rounded-2xl p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
              <h3 class="text-lg font-bold text-text-primary dark:text-text-inverse">OminiX-API</h3>
              <p class="text-sm text-text-secondary dark:text-text-secondary-inverse">本地推理服务器 &mdash; 纯 Rust</p>
            </div>
            <div class="flex flex-wrap gap-3 text-xs text-emerald-700 dark:text-emerald-300">
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">LLM</span>
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">ASR</span>
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">TTS</span>
              <span class="px-2 py-1 bg-white/60 dark:bg-white/10 rounded-full">图像</span>
            </div>
          </div>
        </a>
        <!-- Arrow -->
        <div class="flex justify-center text-gray-400 dark:text-gray-600">
          <div class="text-center">
            <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
            <span class="text-xs">Rust crate 接口</span>
          </div>
        </div>
        <!-- OminiX-MLX -->
