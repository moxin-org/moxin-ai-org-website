---
import Layout from '../layouts/Layout.astro';
import InteractiveStack from '../components/InteractiveStack.jsx';
import TypingEffect from '../components/TypingEffect.jsx';

const base = import.meta.env.BASE_URL;
const mkPath = (path) => {
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return `${cleanBase}${path.startsWith('/') ? path : '/' + path}`;
};
---

<Layout title="Open Ecosystem for Sovereign AI - Moxin Org">
  <div class="relative overflow-hidden">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32">
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8 animate-fade-in">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gray-100 dark:bg-white/10 border border-gray-200 dark:border-white/10 text-sm text-text-secondary dark:text-text-secondary-inverse font-medium backdrop-blur-sm bg-opacity-80">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-blue opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-blue"></span>
              </span>
              Full-Stack Open AI Ecosystem
            </div>
            
            <h1 class="text-5xl font-bold tracking-tight leading-tight text-text-primary dark:text-text-inverse">
              Truly Open, <br />
              <span class="text-accent-blue">
                <TypingEffect client:only="react" words={["Edge-First AI Ecosystem", "Sovereign Intelligence", "Efficient Computing"]} />
              </span>
            </h1>
            
            <p class="text-xl text-text-secondary dark:text-text-secondary-inverse max-w-xl leading-relaxed font-light">
              We are building a version of the AI future that is open, efficient, and sovereign. From Edge to Cloud.
            </p>

            <div class="flex flex-wrap gap-4">
              <a href="https://github.com/moxin-org" target="_blank" class="bg-white/80 dark:bg-white/10 backdrop-blur-sm text-text-primary dark:text-text-inverse border-4 border-black/5 dark:border-white/20 px-8 py-4 rounded-full font-medium transition-all hover:bg-black hover:border-black hover:text-white dark:hover:bg-white dark:hover:text-black hover:scale-105 flex items-center gap-2">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                GitHub
              </a>
              <a href="https://huggingface.co/moxin-org" target="_blank" class="bg-white/80 dark:bg-white/10 backdrop-blur-sm text-text-primary dark:text-text-inverse border-4 border-black/5 dark:border-white/20 px-8 py-4 rounded-full font-medium transition-all hover:bg-[#FFD21E] hover:border-[#FFD21E] hover:text-black dark:hover:bg-[#FFD21E] dark:hover:border-[#FFD21E] dark:hover:text-black hover:scale-105 flex items-center gap-2">
                <img src={mkPath("/images/hf-logo.svg")} class="w-6 h-6" alt="Hugging Face" />
                Hugging Face
              </a>
            </div>


          </div>

          <div class="relative animate-slide-up">
            <div class="relative bg-white/80 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-3xl p-2 shadow-2xl">
              <InteractiveStack client:only="react" lang="en" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Moxin Studio Section -->
    <section class="relative py-24 bg-canvas-grey dark:bg-canvas-dark-grey">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row gap-16 items-center">
          <div class="flex-1 relative">
            <div class="absolute -inset-4 bg-gradient-to-r from-teal-100 to-cyan-50 dark:from-teal-900/30 dark:to-cyan-900/30 rounded-full blur-3xl opacity-30"></div>
            <div class="relative rounded-3xl overflow-hidden shadow-xl border border-gray-200 dark:border-white/10">
              <video class="w-full" autoplay loop muted playsinline poster={mkPath("/images/moxin-studio/screenshot-image-gen.png")}>
                <source src={mkPath("/videos/moxin-studio-demo.mp4")} type="video/mp4" />
              </video>
            </div>
          </div>
          <div class="flex-1 space-y-6">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal-50 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400 text-sm font-bold">
              <span class="w-2 h-2 rounded-full bg-teal-500"></span>
              Desktop App
            </div>
            <h2 class="text-4xl font-bold text-text-primary dark:text-text-inverse">Moxin Studio</h2>
            <p class="text-xl text-text-secondary dark:text-text-secondary-inverse leading-relaxed">
              A native desktop AI app built with <span class="text-text-primary dark:text-text-inverse font-medium">pure Rust and Makepad</span>. Run everything locally on your Mac, no Python required.
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center text-teal-600 dark:text-teal-400 shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <strong class="text-text-primary dark:text-text-inverse">20+ Local Models:</strong> LLMs, VLMs, image generation, ASR, TTS, and video — all on-device.
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center text-teal-600 dark:text-teal-400 shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <strong class="text-text-primary dark:text-text-inverse">Model Hub:</strong> Discover, download, and run models with one click.
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center text-teal-600 dark:text-teal-400 shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <strong class="text-text-primary dark:text-text-inverse">Voice & Vision:</strong> Voice cloning, speech recognition, image generation, and visual understanding.
                </div>
              </li>
            </ul>
            <div class="pt-4">
              <a href={mkPath("/products/moxin-studio")} class="inline-flex items-center gap-2 text-teal-600 dark:text-teal-400 font-bold hover:gap-3 transition-all">
                Explore Moxin Studio
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Moxin Voice Section -->
    <section class="relative py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row gap-16 items-center">
          <div class="flex-1 space-y-6">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-50 dark:bg-purple-900/30 text-[#8B5CF6] text-sm font-bold">
              <span class="w-2 h-2 rounded-full bg-[#8B5CF6]"></span>
              Voice AI
            </div>
            <h2 class="text-4xl font-bold text-text-primary dark:text-text-inverse">Moxin Voice</h2>
            <p class="text-xl text-text-secondary dark:text-text-secondary-inverse leading-relaxed">
              Real-time <span class="text-text-primary dark:text-text-inverse font-medium">live translation, TTS, and voice cloning</span> running entirely on-device in pure Rust.
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-[#8B5CF6] shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <strong class="text-text-primary dark:text-text-inverse">Zero-Shot Voice Cloning:</strong> Create a voice profile from just 5-10 seconds of reference audio.
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-[#8B5CF6] shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <strong class="text-text-primary dark:text-text-inverse">Local TTS + ASR:</strong> No cloud APIs, no latency. 14+ preset voices with custom training support.
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-[#8B5CF6] shrink-0 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <strong class="text-text-primary dark:text-text-inverse">Native Performance:</strong> Built with Rust, Makepad, and GPT-SoVITS v2. Deploying at GOSIM Paris 2026.
                </div>
              </li>
            </ul>
            <div class="pt-4">
              <a href={mkPath("/products/moxin-voice")} class="inline-flex items-center gap-2 text-[#8B5CF6] font-bold hover:gap-3 transition-all">
                Explore Moxin Voice
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
            </div>
          </div>
          <div class="flex-1 relative">
            <div class="absolute -inset-4 bg-gradient-to-r from-purple-100 to-violet-50 dark:from-purple-900/30 dark:to-violet-900/30 rounded-full blur-3xl opacity-30"></div>
            <div class="relative rounded-3xl overflow-hidden shadow-xl border border-gray-200 dark:border-white/10">
              <video class="w-full" autoplay loop muted playsinline preload="metadata">
                <source src={mkPath("/resources/moxin-voice-demo-en.mp4")} type="video/mp4" />
              </video>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Value Props -->
    <section class="relative py-24 bg-canvas-grey dark:bg-canvas-dark-grey">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-12">
          <div class="space-y-4 p-6 rounded-2xl hover:bg-white dark:hover:bg-white/5 transition-colors duration-300">
            <div class="w-12 h-12 bg-blue-50 dark:bg-blue-900/30 rounded-xl flex items-center justify-center text-accent-blue mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-text-primary dark:text-text-inverse">Data Sovereignty</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse leading-relaxed">Your data never leaves your infrastructure. Run fully private AI models on-premise or in your private cloud.</p>
          </div>
          <div class="space-y-4 p-6 rounded-2xl hover:bg-white dark:hover:bg-white/5 transition-colors duration-300">
            <div class="w-12 h-12 bg-purple-50 dark:bg-purple-900/30 rounded-xl flex items-center justify-center text-accent-purple mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-text-primary dark:text-text-inverse">Extreme Efficiency</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse leading-relaxed">Run 70B+ models on consumer hardware. Ominix Edge optimizes inference for up to 30x lower latency.</p>
          </div>
          <div class="space-y-4 p-6 rounded-2xl hover:bg-white dark:hover:bg-white/5 transition-colors duration-300">
            <div class="w-12 h-12 bg-cyan-50 dark:bg-cyan-900/30 rounded-xl flex items-center justify-center text-accent-cyan mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-text-primary dark:text-text-inverse">Full Control</h3>
            <p class="text-text-secondary dark:text-text-secondary-inverse leading-relaxed">Open source from top to bottom. Modify the model, the agent framework, or the inference engine to fit your needs.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
